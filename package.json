{
  "name": "gohit",
  "displayName": "GoHit - API Handler Tester",
  "description": "Test Go API endpoints directly from your code editor",
  "version": "0.1.0",
  "publisher": "gohit",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "api",
    "testing",
    "go",
    "golang",
    "http",
    "rest",
    "gin",
    "fiber",
    "echo"
  ],
  "activationEvents": [
    "onLanguage:go",
    "onView:gohit.testerView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gohit.manageEnvironments",
        "title": "GoHit: Manage Environments",
        "category": "GoHit",
        "icon": "$(settings-gear)"
      },
      {
        "command": "gohit.setOpenRouterApiKey",
        "title": "GoHit: Set OpenRouter API Key",
        "category": "GoHit"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gohit-explorer",
          "title": "GoHit",
          "icon": "$(rocket)"
        }
      ]
    },
    "views": {
      "gohit-explorer": [
        {
          "type": "webview",
          "id": "gohit.testerView",
          "name": "API Tester"
        }
      ]
    },
    "configuration": {
      "title": "GoHit",
      "properties": {
        "gohit.environments": {
          "type": "array",
          "default": [
            {
              "name": "local",
              "baseUrl": "http://localhost:8080"
            }
          ],
          "description": "API environment configurations",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Environment name"
              },
              "baseUrl": {
                "type": "string",
                "description": "Base URL for this environment"
              }
            }
          }
        },
        "gohit.activeEnvironment": {
          "type": "string",
          "default": "local",
          "description": "Currently active environment"
        },
        "gohit.openRouterApiKey": {
          "type": "string",
          "default": "",
          "description": "API Key for OpenRouter (used for AI-powered features)"
        },
        "gohit.openRouterAiModel": {
          "type": "string",
          "default": "anthropic/claude-3-haiku",
          "description": "The AI model to use for generating payloads"
        },
        "gohit.openRouterAiPrompt": {
          "type": "string",
          "default": "",
          "description": "Custom skills or instructions for the AI when generating JSON payloads."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0"
  }
}
